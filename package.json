{
  "name": "gtd-for-outlook",
  "version": "0.1.0",
  "description": "CLI tool that organizes a Microsoft 365 mailbox using the GTD methodology, orchestrated by OpenClaw",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "gtd-outlook": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit"
  },
  "keywords": [
    "gtd",
    "outlook",
    "email",
    "productivity",
    "microsoft-graph",
    "openclaw",
    "ai"
  ],
  "author": "",
  "license": "MIT",
  "engines": {
    "node": ">=22.0.0"
  },
  "dependencies": {
    "@azure/msal-node": "5.1.5",
    "@sinclair/typebox": "0.32.35",
    "commander": "12.1.0",
    "inquirer": "9.3.8",
    "sql.js": "1.11.0"
  },
  "overrides": {},
  "devDependencies": {
    "@types/node": "22.15.30",
    "typescript": "5.9.3",
    "vitest": "3.2.4"
  }
}
