# Microsoft Azure App Registration
# Create an app at: https://portal.azure.com → App Registrations
# Required API permissions: Mail.ReadWrite (delegated)
GRAPH_CLIENT_ID=your-azure-app-client-id
GRAPH_TENANT_ID=your-tenant-id-or-common

# OpenClaw configuration (optional — defaults to local gateway)
# OPENCLAW_GATEWAY_URL=http://localhost:3000
# OPENCLAW_API_KEY=your-openclaw-api-key

# Graph API request logging (advanced debugging)
# Enable file logging for all Graph API requests/responses to a log file
# Set LOG_GRAPH_API_TO_FILE=true to enable, false or unset to disable
LOG_GRAPH_API_TO_FILE=false

# Path to write Graph API logs (optional, required when LOG_GRAPH_API_TO_FILE=true)
# Logs will be appended to this file with timestamps for each request/response/error
LOG_GRAPH_API_FILE_PATH=/tmp/gtd-for-outlook/graph-api.log
